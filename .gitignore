# ============================================
# GigAegis — Monorepo .gitignore
# Optimized for Node.js + Vite + React
# ============================================

# ── Dependencies ───────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ───────────────────────────
dist/
build/
*.tgz

# ── Environment & Secrets ──────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env

# ── Logs ───────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS artifacts ───────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Editor configs ─────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Coverage & Testing ─────────────────────
coverage/
.nyc_output/

# ── Vite cache ─────────────────────────────
gigaegis-frontend/.vite/

# ── Misc ───────────────────────────────────
*.tsbuildinfo
