# ============================================
# GigAegis Backend — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── Server ──────────────────────────────────
PORT=3000

# ── MongoDB ─────────────────────────────────
# Leave blank to use in-memory fallback (works for demos)
MONGODB_URI=

# ── OpenWeather API ─────────────────────────
# Get a free key: https://openweathermap.org/api
# Required for live weather triggers. Without it,
# the system falls back to simulation defaults.
OPENWEATHER_API_KEY=your_api_key_here

# ── ML Configuration (Optional) ────────────
# These are hardcoded defaults; override only if needed.
# ML_TREES=50
# ML_LEARNING_RATE=0.1
# ML_MAX_DEPTH=4
# FRAUD_ISOLATION_TREES=100
# FRAUD_MAX_SAMPLES=256
